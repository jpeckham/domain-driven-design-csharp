@using SocialDDD.Client.Services
@inject NavigationManager Nav
@inject IJSRuntime JS

<article class="post" @onclick="OpenPost">
    <div class="post-header">
        <div class="post-author-block">
            <AuthorThumbnail DisplayName="@AuthorName" Handle="@AuthorHandle" ImageUrl="@Post.AuthorProfileImageUrl" />
            <span class="post-time">@Post.PostedAt.ToLocalTime().ToString("g")</span>
        </div>
        @if (IsOwner && OnDelete.HasDelegate)
        {
            <div class="actions">
                <button type="button" class="secondary compact" @onclick="() => OnDelete.InvokeAsync(Post.PostId)" @onclick:stopPropagation="true">Delete</button>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(Post.Content))
    {
        <PostContent Content="@Post.Content" />
    }

    @if (Post.OriginalPost is not null)
    {
        <div class="embedded-post">
            <span>Reposted by @AuthorHandle</span>
            <PostContent Content="@Post.OriginalPost.Content" />
        </div>
    }

    <PostMediaGrid Media="@Post.Media" />

    <div class="post-actions" aria-label="Post actions">
        <button type="button" class="heart-button @(Post.LikedByMe ? "liked" : "")" title="Like" @onclick="() => OnLike.InvokeAsync(Post.PostId)" @onclick:stopPropagation="true">
            ♥ <span>@Post.LikeCount</span>
        </button>
        <button type="button" class="reply-button" title="Reply" @onclick="() => OnReply.InvokeAsync(Post.PostId)" @onclick:stopPropagation="true">
            ↩ <span>@Post.ReplyCount</span>
        </button>
        <button type="button" class="repost-button @(Post.IsRepostedByMe ? "liked" : "")" title="@RepostTitle" disabled="@IsRepost" @onclick="RepostAsync" @onclick:stopPropagation="true">
            ↻ <span>@Post.RepostCount</span>
        </button>
        <button type="button" class="share-button" title="Share" @onclick="SharePostAsync" @onclick:stopPropagation="true">
            Share
        </button>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public PostApiService.PostDto Post { get; set; } = null!;
    [Parameter] public bool IsOwner { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }
    [Parameter] public EventCallback<Guid> OnLike { get; set; }
    [Parameter] public EventCallback<Guid> OnReply { get; set; }
    [Parameter] public EventCallback<Guid> OnRepost { get; set; }

    private string AuthorName => string.IsNullOrWhiteSpace(Post.AuthorDisplayName)
        ? Post.AuthorId.ToString()
        : Post.AuthorDisplayName;
    private string AuthorHandle => string.IsNullOrWhiteSpace(Post.AuthorHandle)
        ? $"@{Post.AuthorId.ToString()[..8]}"
        : Post.AuthorHandle;

    private bool IsRepost => Post.OriginalPostId is not null;
    private string RepostTitle => IsRepost ? "Reposts cannot be reposted" : "Repost";

    private void OpenPost()
    {
        Nav.NavigateTo($"/posts/{Post.PostId}");
    }

    private async Task SharePostAsync()
    {
        var url = Nav.ToAbsoluteUri($"/posts/{Post.PostId}").ToString();
        await JS.InvokeAsync<string?>("prompt", "Copy post URL", url);
    }

    private async Task RepostAsync()
    {
        if (IsRepost) return;
        await OnRepost.InvokeAsync(Post.PostId);
    }
}
