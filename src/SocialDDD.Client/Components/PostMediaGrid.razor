@using SocialDDD.Client.Services

@if (Media is { Count: > 0 })
{
    <div class="post-media-grid media-count-@Media.Count">
        @foreach (var item in Media.OrderBy(m => m.SortOrder))
        {
            if (item.Kind.Equals("Video", StringComparison.OrdinalIgnoreCase))
            {
                <video controls src="@item.Url"></video>
            }
            else
            {
                <a href="@item.Url" target="_blank" rel="noopener">
                    <img src="@item.Url" alt="@item.AltText" />
                </a>
            }
        }
    </div>
}

@code {
    [Parameter] public IReadOnlyList<PostApiService.PostMediaDto>? Media { get; set; }
}
