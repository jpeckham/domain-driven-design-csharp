@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav

<main class="shell">
    <nav class="top-nav">
        <a href="/feed">Home</a>
        <a href="/feed?q=">Search</a>
        @if (!string.IsNullOrWhiteSpace(_currentHandle))
        {
            <a href="@($"/profile/{_currentHandle.TrimStart('@')}")">Profile</a>
            <span class="nav-user">@_displayName</span>
            <button type="button" class="secondary compact" @onclick="LogoutAsync">Log out</button>
        }
        else
        {
            <a href="/login">Log in</a>
            <a href="/register">Register</a>
        }
    </nav>
    @Body
    <ToastContainer />
</main>

@code {
    private string? _currentHandle;
    private string? _displayName;

    protected override async Task OnInitializedAsync()
    {
        var user = await Auth.GetCurrentUserAsync();
        _currentHandle = user?.Handle;
        _displayName = user?.DisplayName;
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        _currentHandle = null;
        _displayName = null;
        Nav.NavigateTo("/login");
    }
}
