@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav

<section class="auth">
    <div class="auth-panel">
        <h1>SocialDDD</h1>
        <p>Log in to read recent posts and publish as yourself.</p>

        <form @onsubmit="HandleLogin">
            <input type="email" @bind="_email" placeholder="email@example.com" />
            <input type="password" @bind="_password" placeholder="Password" />
            <button type="submit" disabled="@_busy">Log In</button>
        </form>

        <p class="switch"><a href="/forgot-password">Forgot password?</a></p>
        <p class="switch">Need an account? <a href="/register">Create one</a></p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="field-message">@_error</p>
        }
    </div>
</section>

@code {
    private string _email = "";
    private string _password = "";
    private string _error = "";
    private bool _busy;

    private async Task HandleLogin()
    {
        _busy = true;
        _error = "";

        try
        {
            var deviceId = await Auth.GetOrCreateDeviceIdAsync();
            var result = await Auth.LoginWithDeviceAsync(_email, _password, deviceId);
            if (result.IsSuccess)
            {
                Nav.NavigateTo("/feed");
            }
            else if (result.RequiresOtp)
            {
                Nav.NavigateTo($"/verify-device?email={Uri.EscapeDataString(_email)}&deviceId={Uri.EscapeDataString(deviceId)}");
            }
            else
            {
                _error = result.Error ?? "Invalid email or password.";
            }
        }
        catch
        {
            _error = "Login failed. Please try again.";
        }
        finally
        {
            _busy = false;
        }
    }
}
