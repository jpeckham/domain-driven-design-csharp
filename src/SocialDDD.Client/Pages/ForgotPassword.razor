@page "/forgot-password"
@inject AuthService Auth

<section class="auth">
    <div class="auth-panel">
        <h1>Reset Password</h1>
        <p>Enter your email address and check your inbox for a reset link.</p>

        @if (_sent)
        {
            <p class="message">If that email address is registered, a password reset link has been sent.</p>
            <p class="switch"><a href="/login">Back to login</a></p>
        }
        else
        {
            <form @onsubmit="HandleRequest">
                <input type="email" @bind="_email" placeholder="email@example.com" />
                <button type="submit" disabled="@_busy">Send reset link</button>
            </form>

            <p class="switch"><a href="/login">Back to login</a></p>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="field-message">@_error</p>
        }
    </div>
</section>

@code {
    private string _email = "";
    private string _error = "";
    private bool _busy;
    private bool _sent;

    private async Task HandleRequest()
    {
        _busy = true;
        _error = "";

        try
        {
            await Auth.RequestPasswordResetAsync(_email);
        }
        catch
        {
            // Keep the same user-facing result for all password reset request outcomes.
        }
        finally
        {
            _sent = true;
            _busy = false;
        }
    }
}
