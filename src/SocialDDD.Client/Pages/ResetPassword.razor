@page "/reset-password"
@inject AuthService Auth
@inject NavigationManager Nav

<section class="auth">
    <div class="auth-panel">
        <h1>Set New Password</h1>
        <p>Choose a new password for your account.</p>

        <form @onsubmit="HandleReset">
            <input type="password" @bind="_newPassword" placeholder="New password" />
            <input type="password" @bind="_confirmPassword" placeholder="Confirm password" />
            <button type="submit" disabled="@_busy">Reset password</button>
        </form>

        <p class="switch"><a href="/login">Back to login</a></p>

        @if (!string.IsNullOrEmpty(_message))
        {
            <p class="message">@_message</p>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="field-message">@_error</p>
        }
    </div>
</section>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private string _newPassword = "";
    private string _confirmPassword = "";
    private string _error = "";
    private string _message = "";
    private bool _busy;

    private async Task HandleReset()
    {
        _busy = true;
        _error = "";
        _message = "";

        try
        {
            if (string.IsNullOrWhiteSpace(Token))
            {
                _error = "Reset token is missing.";
            }
            else if (_newPassword != _confirmPassword)
            {
                _error = "Passwords do not match.";
            }
            else
            {
                _error = await Auth.ResetPasswordAsync(Token, _newPassword) ?? "";
                if (string.IsNullOrEmpty(_error))
                {
                    _message = "Password updated — please log in.";
                    await Task.Delay(2000);
                    Nav.NavigateTo("/login");
                }
            }
        }
        catch
        {
            _error = "Password reset failed. Please try again.";
        }
        finally
        {
            _busy = false;
        }
    }
}
