@page "/feed"
@page "/"
@inject PostApiService PostApi
@inject AuthService Auth
@inject NavigationManager Nav

<section class="workspace">
    <header class="masthead">
        <div>
            <h1>Recent Posts</h1>
            @if (_username is not null)
            {
                <p>Signed in as @_username</p>
            }
        </div>
        @if (_username is not null)
        {
            <div class="actions">
                <button type="button" class="secondary" @onclick="Logout">Log Out</button>
            </div>
        }
    </header>

    <div class="feed-layout">
        @if (_username is not null)
        {
            <section class="panel composer">
                <div class="composer-header">
                    <h2>Create Post</h2>
                    <p>Post as @_username</p>
                </div>
                <form @onsubmit="CreatePost">
                    <textarea @bind="_newContent" class="composer-input" placeholder="Share an update with your network." maxlength="280"></textarea>
                    <div class="composer-submit-row">
                        <span>@(_newContent.Length) / 280</span>
                        <button type="submit" disabled="@_busy">Post</button>
                    </div>
                </form>
            </section>
        }
        else
        {
            <section class="panel">
                <p class="empty"><a href="/login">Log in</a> or <a href="/register">register</a> to post.</p>
            </section>
        }

        <section class="feed">
            <div class="feed-title-row">
                <h2>Recent</h2>
            </div>
            @if (_posts.Count == 0)
            {
                <p class="empty">No posts yet.</p>
            }
            else
            {
                @foreach (var post in _posts)
                {
                    <article class="post">
                        <div class="post-header">
                            <div class="post-author-block">
                                <div class="post-author-line">
                                    <span>@post.AuthorId</span>
                                    <span class="post-time">@post.PostedAt.ToLocalTime().ToString("g")</span>
                                </div>
                            </div>
                            @if (_currentUserId == post.AuthorId)
                            {
                                <div class="actions">
                                    <button type="button" class="secondary compact" @onclick="() => DeletePost(post.PostId)">Delete</button>
                                </div>
                            }
                        </div>
                        <p>@post.Content</p>
                    </article>
                }
            }
        </section>
    </div>
</section>

@code {
    private List<PostApiService.PostDto> _posts = [];
    private Guid? _currentUserId;
    private string? _username;
    private string _newContent = "";
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (!await Auth.InitializeAsync())
        {
            Nav.NavigateTo("/login");
            return;
        }
        _currentUserId = await Auth.GetCurrentUserIdAsync();
        _username = await Auth.GetCurrentUsernameAsync();
        await LoadFeedAsync();
    }

    private async Task LoadFeedAsync() =>
        _posts = await PostApi.GetFeedAsync();

    private async Task CreatePost()
    {
        if (_currentUserId is null || string.IsNullOrWhiteSpace(_newContent)) return;

        _busy = true;
        await PostApi.CreateAsync(_currentUserId.Value, _newContent);
        _newContent = "";
        await LoadFeedAsync();
        _busy = false;
    }

    private async Task DeletePost(Guid postId)
    {
        await PostApi.DeleteAsync(postId);
        await LoadFeedAsync();
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        _currentUserId = null;
        _username = null;
    }
}
