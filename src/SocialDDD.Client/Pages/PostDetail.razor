@page "/posts/{PostId:guid}"
@inject PostApiService PostApi
@inject AuthService Auth
@inject NavigationManager Nav

<section class="workspace single-post-feed">
    @if (_loading)
    {
        <p class="status">Loading conversation...</p>
    }
    else if (_conversation is null)
    {
        <p class="empty">Post not found.</p>
    }
    else
    {
        @if (_conversation.ParentPost is not null)
        {
            <div class="reply-context embedded-post" role="link" tabindex="0" @onclick="OpenParentPost">
                <div class="post-header">
                    <div class="post-author-block">
                        <AuthorThumbnail DisplayName="@ParentAuthorName" Handle="@ParentAuthorHandle" ImageUrl="@_conversation.ParentPost.AuthorProfileImageUrl" />
                        <span class="post-time">@_conversation.ParentPost.PostedAt.ToLocalTime().ToString("g")</span>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(_conversation.ParentPost.Content))
                {
                    <PostContent Content="@_conversation.ParentPost.Content" />
                }
                @if (_conversation.ParentPost.OriginalPost is not null)
                {
                    <div class="embedded-post">
                        <span>Reposted by @ParentAuthorHandle</span>
                        <PostContent Content="@_conversation.ParentPost.OriginalPost.Content" />
                        <PostMediaGrid Media="@_conversation.ParentPost.OriginalPost.Media" />
                    </div>
                }
                <PostMediaGrid Media="@_conversation.ParentPost.Media" />
            </div>
        }

        <PostCard
            Post="_conversation.Post"
            IsOwner="@(_currentUserId == _conversation.Post.AuthorId)"
            OnDelete="DeletePostAsync"
            OnLike="ToggleLikeAsync"
            OnReply="OpenReply"
            OnRepost="RepostAsync" />

        @if (_conversation.Post.ParentPostId is not null)
        {
            <p class="status">Replying in a conversation</p>
        }

        @foreach (var item in FlattenReplies(_conversation.Replies, 1).Where(i => i.Level <= 3))
        {
            <div class="reply-level reply-level-@item.Level">
                <PostCard
                    Post="item.Node.Post"
                    IsOwner="@(_currentUserId == item.Node.Post.AuthorId)"
                    OnDelete="DeletePostAsync"
                    OnLike="ToggleLikeAsync"
                    OnReply="OpenReply"
                    OnRepost="RepostAsync" />
            </div>
        }

        <form class="inline-composer" @onsubmit="SubmitReplyAsync">
            @if (!string.IsNullOrWhiteSpace(ReplyTargetHandle))
            {
                <p class="reply-target">Replying to @ReplyTargetHandle</p>
            }
            <textarea @bind="_replyContent" maxlength="@ReplyContentMaxLength"></textarea>
            <MediaAttachmentStrip @bind-AssetIds="_replyMediaAssetIds" />
            <div class="composer-submit-row">
                <span>@StoredReplyLength / 280</span>
                <button type="submit" disabled="@_busy">Reply</button>
            </div>
        </form>
    }
</section>

@code {
    [Parameter] public Guid PostId { get; set; }

    private PostApiService.PostConversationDto? _conversation;
    private Guid? _currentUserId;
    private Guid? _replyingTo;
    private string _replyContent = "";
    private List<Guid> _replyMediaAssetIds = [];
    private bool _loading = true;
    private bool _busy;
    private string? ReplyTargetHandle => FindPost(_replyingTo)?.AuthorHandle;
    private string ParentAuthorName => string.IsNullOrWhiteSpace(_conversation?.ParentPost?.AuthorDisplayName)
        ? _conversation?.ParentPost?.AuthorId.ToString() ?? "Unknown"
        : _conversation.ParentPost.AuthorDisplayName;
    private string ParentAuthorHandle => string.IsNullOrWhiteSpace(_conversation?.ParentPost?.AuthorHandle)
        ? $"@{_conversation?.ParentPost?.AuthorId.ToString()[..8]}"
        : _conversation.ParentPost.AuthorHandle;
    private int ReplyPrefixLength => string.IsNullOrWhiteSpace(ReplyTargetHandle) ? 0 : ReplyTargetHandle.Length + 1;
    private int ReplyContentMaxLength => Math.Max(1, 280 - ReplyPrefixLength);
    private int StoredReplyLength => ReplyPrefixLength + _replyContent.Length;

    protected override async Task OnParametersSetAsync()
    {
        await Auth.InitializeAsync();
        _currentUserId = await Auth.GetCurrentUserIdAsync();
        _conversation = await PostApi.GetPostWithConversationAsync(PostId);
        _replyingTo = PostId;
        _replyContent = "";
        _loading = false;
    }

    private IEnumerable<(PostApiService.PostConversationDto Node, int Level)> FlattenReplies(
        IEnumerable<PostApiService.PostConversationDto> nodes,
        int level)
    {
        foreach (var node in nodes)
        {
            yield return (node, level);
            foreach (var child in FlattenReplies(node.Replies, level + 1))
                yield return child;
        }
    }

    private async Task DeletePostAsync(Guid postId)
    {
        if (await PostApi.DeleteAsync(postId))
            _conversation = await PostApi.GetPostWithConversationAsync(PostId);
    }

    private async Task ToggleLikeAsync(Guid postId)
    {
        await PostApi.LikePostAsync(postId);
        _conversation = await PostApi.GetPostWithConversationAsync(PostId);
    }

    private void OpenReply(Guid postId)
    {
        _replyingTo = postId;
        _replyContent = "";
        _replyMediaAssetIds = [];
    }

    private async Task RepostAsync(Guid postId)
    {
        await PostApi.CreateRepostAsync(postId);
        _conversation = await PostApi.GetPostWithConversationAsync(PostId);
    }

    private void OpenParentPost()
    {
        if (_conversation?.ParentPost is null) return;
        Nav.NavigateTo($"/posts/{_conversation.ParentPost.PostId}");
    }

    private async Task SubmitReplyAsync()
    {
        if (_replyingTo is null || string.IsNullOrWhiteSpace(_replyContent)) return;
        _busy = true;
        await PostApi.CreateReplyAsync(_replyingTo.Value, _replyContent, _replyMediaAssetIds);
        _conversation = await PostApi.GetPostWithConversationAsync(PostId);
        _replyingTo = PostId;
        _replyContent = "";
        _replyMediaAssetIds = [];
        _busy = false;
    }

    private PostApiService.PostDto? FindPost(Guid? postId)
    {
        if (postId is null || _conversation is null) return null;
        if (_conversation.Post.PostId == postId.Value) return _conversation.Post;
        if (_conversation.ParentPost?.PostId == postId.Value) return _conversation.ParentPost;

        return FlattenReplies(_conversation.Replies, 1)
            .Select(item => item.Node.Post)
            .FirstOrDefault(post => post.PostId == postId.Value);
    }
}
