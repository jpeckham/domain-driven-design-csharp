@page "/register"
@inject AuthService Auth
@inject NavigationManager Nav

<section class="auth">
    <div class="auth-panel">
        <h1>Create Account</h1>
        <p>Use your account to post only as yourself.</p>

        <form @onsubmit="HandleRegister">
            <input @bind="_displayName" placeholder="Display name" />
            <input @bind="_handle" placeholder="handle (e.g. alice_123)" />
            <input type="email" @bind="_email" placeholder="email@example.com" />
            <input type="password" @bind="_password" placeholder="Password" />
            <button type="submit" disabled="@_busy">Create Account</button>
        </form>

        <p class="switch">Already have an account? <a href="/login">Log in</a></p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="field-message">@_error</p>
        }
    </div>
</section>

@code {
    private string _handle = "";
    private string _displayName = "";
    private string _email = "";
    private string _password = "";
    private string _error = "";
    private bool _busy;

    private async Task HandleRegister()
    {
        _busy = true;
        _error = await Auth.RegisterAsync(_handle, _email, _password, _handle, _displayName) ?? "";
        if (string.IsNullOrEmpty(_error))
            Nav.NavigateTo("/feed");
        _busy = false;
    }
}
