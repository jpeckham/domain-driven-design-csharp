@page "/register"
@inject AuthService Auth
@inject NavigationManager Nav

<h2>Register</h2>

@if (!string.IsNullOrEmpty(_error))
{
    <p style="color:red">@_error</p>
}

<div>
    <label>Username</label>
    <input @bind="_username" />
</div>
<div>
    <label>Email</label>
    <input type="email" @bind="_email" />
</div>
<div>
    <label>Password</label>
    <input type="password" @bind="_password" />
</div>
<button @onclick="HandleRegister" disabled="@_busy">Register</button>
<a href="/login">Already have an account?</a>

@code {
    private string _username = "";
    private string _email = "";
    private string _password = "";
    private string _error = "";
    private bool _busy;

    private async Task HandleRegister()
    {
        _busy = true;
        _error = "";

        var ok = await Auth.RegisterAsync(_username, _email, _password);
        if (ok)
            Nav.NavigateTo("/feed");
        else
            _error = "Registration failed. Username or email may already be taken.";

        _busy = false;
    }
}
