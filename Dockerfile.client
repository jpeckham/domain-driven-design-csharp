FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY SocialDDD.sln .
COPY src/SocialDDD.Client/SocialDDD.Client.csproj src/SocialDDD.Client/
RUN dotnet restore src/SocialDDD.Client/SocialDDD.Client.csproj

COPY src/SocialDDD.Client/ src/SocialDDD.Client/
RUN dotnet publish src/SocialDDD.Client/SocialDDD.Client.csproj \
      -c Release -o /app/publish --no-restore

FROM nginx:alpine
COPY --from=build /app/publish/wwwroot /usr/share/nginx/html
COPY nginx.conf /etc/nginx/nginx.conf
